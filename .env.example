# Backblaze B2 / object storage (private bucket)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=ticketz-media
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_PUBLIC_URL=
B2_USE_PRIVATE_ACCESS=true
B2_SIGNED_URL_TTL_SECONDS=900

# Media lifecycle
MEDIA_RETENTION_DAYS=60
MEDIA_CLEANUP_BATCH_SIZE=500
MEDIA_CLEANUP_ENABLED=true
MEDIA_ORPHAN_MIN_AGE_DAYS=7
STORAGE_KEY_LAYOUT=companies
MEDIA_ACCESS_TOKEN_SECRET=

# Backend
BACKEND_URL=http://localhost:8080
REDIS_URI=redis://127.0.0.1:6379
