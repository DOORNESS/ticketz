# Copie este arquivo para .env-backend-supabase e preencha com os dados do Supabase.
# Não commite .env-backend-supabase (contém credenciais).
#
# Supabase → Project Settings → Database → Connection string (URI / Session mode)

FRONTEND_HOST=localhost
FRONTEND_PORT=3000
BACKEND_PATH=/backend

EMAIL_ADDRESS=admin@ticketz.host
TZ=America/Sao_Paulo

BACKEND_URL=http://${FRONTEND_HOST}:${FRONTEND_PORT}${BACKEND_PATH}
FRONTEND_URL=http://${FRONTEND_HOST}:${FRONTEND_PORT}

# PostgreSQL externo (Supabase)
DB_DIALECT=postgres
DB_HOST=db.SEU_PROJECT_REF.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASS=COLOQUE_SUA_SENHA_AQUI
DB_NAME=postgres
DB_SCHEMA=ticketz
DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
DB_TIMEZONE=-03:00
# Pool reduzido — Supabase limita conexões simultâneas
DB_MAX_CONNECTIONS=5
DB_MIN_CONNECTIONS=1

# Redis local (container Docker na rede ticketz)
REDIS_URI=redis://redis:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

VERIFY_TOKEN=ticketz
SOCKET_ADMIN=true

# - Schema isolado Ticketz (mesmo projeto Supabase Fortmax):
DB_SCHEMA=ticketz
# - Conexão direct (porta 5432): recomendada para migrations/seeds manuais.
# - Connection pooler (porta 6543, user postgres.PROJECT_REF): ok para runtime;
#   algumas migrations podem exigir conexão direct.
# - Se falhar por certificado SSL no Docker, descomente DB_SSL_REJECT_UNAUTHORIZED=false.
